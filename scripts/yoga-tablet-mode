#!/usr/bin/env python3
"""
Monitor the Lenovo Yoga hinge switch and rebind the touchpad driver when
returning to laptop mode. Rebind resets libinput's state, which inhibit alone
does not. Runs as root (system service).
"""
import glob
import sys
import time
from pathlib import Path
from evdev import InputDevice, ecodes, list_devices


def find_switch() -> str | None:
    for path in list_devices():
        try:
            if "Lenovo Yoga Tablet Mode Control" in InputDevice(path).name:
                return path
        except Exception:
            continue
    return None


def find_hid_id() -> str | None:
    for name_path in glob.glob("/sys/bus/hid/drivers/hid-multitouch/*/"):
        hid_id = Path(name_path).name
        # ELAN vendor 04F3, product 327E
        if "04F3:327E" in hid_id.upper():
            return hid_id
    return None


def rebind(hid_id: str) -> None:
    base = Path("/sys/bus/hid/drivers/hid-multitouch")
    (base / "unbind").write_text(hid_id)
    time.sleep(0.5)
    (base / "bind").write_text(hid_id)
    print(f"Rebound {hid_id}", flush=True)


def main() -> None:
    switch_path = find_switch()
    if not switch_path:
        sys.exit("Could not find Lenovo Yoga Tablet Mode Control switch")

    hid_id = find_hid_id()
    if not hid_id:
        sys.exit("Could not find ELAN touchpad in hid-multitouch")

    dev = InputDevice(switch_path)
    print(f"Monitoring {dev.name}, touchpad HID id: {hid_id}", flush=True)

    # Always rebind at startup to recover from any stuck state after boot
    print("Startup rebind...", flush=True)
    rebind(hid_id)

    for event in dev.read_loop():
        if event.type == ecodes.EV_SW and event.code == ecodes.SW_TABLET_MODE:
            state = "tablet" if event.value else "laptop"
            print(f"Tablet mode: {state}", flush=True)
            if event.value == 0:
                rebind(hid_id)


if __name__ == "__main__":
    main()
